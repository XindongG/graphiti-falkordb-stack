# ---------------------------------------------------------------------------
# graphiti-falkordb-stack — environment configuration
#
# Copy this file to `.env` and fill in the required values before running
# `docker compose up -d`. Never commit a populated `.env` to version control.
# ---------------------------------------------------------------------------

# ----- Required: bind address ----------------------------------------------
# Where to expose the MCP HTTP ports (8001/8002/8003) on the host.
#   127.0.0.1 = local-only (recommended for personal/dev use)
#   0.0.0.0   = all interfaces (only do this behind a firewall / VPN)
#   <tailscale ip> = bind to a Tailscale interface (run `tailscale ip -4`)
BIND_HOST=127.0.0.1

# ----- Required: secrets ---------------------------------------------------
# Generate with: openssl rand -hex 32
FALKORDB_PASSWORD=replace-with-random-32-byte-hex
# Generate with: openssl rand -hex 16
FALKORDB_BROWSER_ENCRYPTION_KEY=replace-with-random-16-byte-hex

# ----- LLM provider --------------------------------------------------------
# Default below targets Volcengine ARK (Mimo). Adjust for your own provider.
LLM_PROVIDER=openai
LLM_MODEL=mimo-v2.5-pro
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=4096

# OpenAI-compatible chat endpoint (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=replace-with-your-llm-api-key
OPENAI_API_URL=https://your-openai-compatible-endpoint/v1
OPENAI_ORGANIZATION_ID=
OPENAI_CHAT_RESPONSE_FORMAT=json_schema
OPENAI_USE_CHAT_COMPLETIONS_JSON_SCHEMA=true
OPENAI_CHAT_SCHEMA_IN_PROMPT=true
OPENAI_CHAT_DISABLE_THINKING=false
OPENAI_CLIENT_TIMEOUT=600

# Anthropic-compatible endpoint (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://your-anthropic-compatible-endpoint
ANTHROPIC_BASE_URL=https://your-anthropic-compatible-endpoint

# ----- Embedding provider --------------------------------------------------
EMBEDDER_PROVIDER=openai
EMBEDDER_MODEL=text-embedding-v4
EMBEDDER_DIMENSIONS=2048
OPENAI_EMBEDDING_API_KEY=replace-with-your-embedding-api-key
OPENAI_EMBEDDING_API_URL=https://your-embedding-endpoint/v1
OPENAI_EMBEDDING_ORGANIZATION_ID=
OPENAI_EMBEDDING_MAX_BATCH_SIZE=10

# ----- Tunables (sensible defaults; usually leave alone) -------------------
# Per-graphiti concurrency cap on falkordb (lower = safer under shared falkordb)
SEMAPHORE_LIMIT=2

# Docker resource caps. The defaults are intentionally conservative so a fresh
# clone can start on low-CPU Docker Desktop / CI environments. Increase them on
# production hosts if you have more CPU available.
FALKORDB_CPUS=1.0
FALKORDB_RESERVED_CPUS=0.5
FALKORDB_MEMORY=3G
FALKORDB_RESERVED_MEMORY=1G
GRAPHITI_CPUS=0.7
GRAPHITI_RESERVED_CPUS=0.2
GRAPHITI_MEMORY=768M
GRAPHITI_RESERVED_MEMORY=256M

# Cap on the number of OR terms in a fulltext query (RedisSearch on FalkorDB
# becomes very expensive past ~6 OR terms). Patched build_fulltext_query reads
# this env. Set to 0 to disable the cap.
FALKORDB_FULLTEXT_MAX_TERMS=6

# FalkorDB database name used by all three Graphiti instances by default.
FALKORDB_DATABASE=agent_memory
